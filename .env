# Settings for the ShopSphere Playwright backend.
# Real environment variables take precedence over anything set here.

# Show the browser window instead of running headless.
SHOP_HEADLESS="false"

# Pause this many ms between Playwright actions so a visible run is followable.
# 0 = full speed. 500 is a comfortable pace to watch.
SHOP_SLOWMO="500"

# Where results are written, relative to backend/.
SHOP_OUTPUT="enquiries.json"

# Demo site accepts any well-formed credentials.
SHOP_EMAIL="test@example.com"
SHOP_PASSWORD="Password123"

SHOP_BASE_URL="https://react-test-shop-five.vercel.app"

# Postgres. DB_HOST must point at the machine running the database --
# change it from localhost to that machine's IP or hostname.
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="scrapper_db"
DB_USER="postgres"
DB_PASSWORD="root"
DB_SSLMODE="disable"
